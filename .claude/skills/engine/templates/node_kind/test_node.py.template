from agent_composer.nodes.base import Output
from agent_composer.nodes.xxx import XxxNode


def test_xxx_runs_pure():
    # The node is a pure function of its bound record — call run() directly.
    node = XxxNode("n", param="...")
    out = node.run({"a": 1})
    assert isinstance(out, Output)
    assert out.value == ...  # the one value


def test_xxx_end_to_end():
    # Load a tiny flow that uses the kind, run it, assert the terminal value.
    from agent_composer import load_flow
    from agent_composer.compose.run import run_flow

    flow = """
id: t
name: t
input:
  x: str
nodes:
  n:
    kind: xxx
    input:
      a: ${input.x}
    output: str
    # ...kind-specific fields (e.g. the `param` your descriptor declares)
output: ${n.output}
"""
    rec = run_flow(load_flow(flow), {"x": "hi"})
    assert rec.status == "succeeded"
    assert rec.output == ...
